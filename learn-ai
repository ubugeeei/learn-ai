#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

usage() {
  cat <<'EOF'
learn-ai — guided commands for the Scala 3 AI course

Usage:
  ./learn-ai <command>

Start with:
  ./learn-ai model        Train the smallest Transformer and generate text.
  ./learn-ai training     Run the train/validation experiment.
  ./learn-ai train ...    Train on your own UTF-8 corpus and save artifacts.

Commands:
  help          Show this explanation.
  model         Train tiny MiniGPT on one repeated phrase, then generate text.
  gpt-lineage   Reproduce GPT-2 parameter inventories and compatibility boundaries.
  training      Train MiniGPT with batches, validation, scheduling, and metrics.
  train         Production-shaped file-to-artifacts workflow; use train --help.
  diagnostics   Check MiniGPT gradients, parameter bytes, and local timing.
  cache         Compare ordinary decoding with KV-cached decoding.
  quantization  Compress a matrix to int8 and report numerical/byte error.
  agent         Run deterministic agent outcome, tool, and permission scenarios.
  planning      Run the task-graph planner with retry and recovery.
  foundations   Run the introductory Scala values/functions/error-handling lab.
  complexity    Compare deterministic work, layout, allocation, and payload costs.
  jvm           Inspect JVM capacity, bounded work, and atomic file publication.
  linear-algebra Inspect rank, eigen residuals, conditioning, and low-rank structure.
  statistics    Estimate uncertainty and probability calibration.
  tensor-execution Inspect broadcasting, batches, views, and graph lifetime.
  precision     Compare FP16, BF16, accumulation, and dynamic loss scaling.
  xor           Train a small MLP to solve XOR.
  bigram        Train the simpler pre-Transformer language model.
  corpus-shards Build and verify a resumable immutable corpus shard set.
  test          Compile the repository and run every automated test.
  tour          Run model, training, diagnostics, and agent in that order.

Nothing here calls a remote AI API. All models and fake-agent scenarios run
locally on the CPU using the Scala/JDK implementation in this repository.
EOF
}

require_nix() {
  if ! command -v nix >/dev/null 2>&1; then
    cat >&2 <<'EOF'
Nix was not found on PATH.

Install Nix first, then return to this directory and run:
  ./learn-ai model

See docs/01-foundations/01-environment.md for the environment explanation.
EOF
    exit 1
  fi
}

explain() {
  local title="$1"
  local purpose="$2"
  local evidence="$3"
  local limitation="$4"

  printf '\n=== %s ===\n\n' "$title"
  printf 'What runs:\n  %s\n\n' "$purpose"
  printf 'What to inspect:\n  %s\n\n' "$evidence"
  printf 'What it does not prove:\n  %s\n\n' "$limitation"
}

run_main() {
  local lesson="$1"
  printf 'Underlying command:\n  nix develop -c sbt '\''runMain learnai.Main %s'\''\n\n' "$lesson"
  nix develop -c sbt "runMain learnai.Main $lesson"
}

run_model() {
  explain \
    "Tiny MiniGPT: train and generate" \
    "A one-layer causal Transformer learns next-token prediction from a repeated 'to be or not to be' corpus, then samples a continuation." \
    "Initial/final loss should fall sharply; generated text should reproduce parts of the tiny training pattern." \
    "This does not show broad language ability or generalization. The corpus is deliberately tiny and repetitive."
  run_main model
}

run_gpt_lineage() {
  explain \
    "GPT research and implementation lineage" \
    "Published GPT-2 configurations are counted exactly, including LayerNorm, biases, four-times GELU MLPs, learned positions, and tied output ownership." \
    "Compare all four checkpoint totals and read every architectural reason MiniGPT cannot load GPT-2 weights." \
    "Parameter-count parity is necessary but does not prove tokenizer, forward-logit, sampling, data, or training parity."
  run_main gpt-lineage
}

run_training() {
  explain \
    "MiniGPT training system" \
    "A byte-level corpus is split into disjoint training/validation regions. MiniGPT trains with batches, microbatch accumulation, AdamW, gradient clipping, and warmup/cosine learning rates." \
    "Follow validation loss, learning rate, gradient norm, clipping scale, tokens seen, and the canonical experiment ID." \
    "A falling loss on one synthetic corpus does not establish real-world model quality."
  run_main training
}

run_training_workflow() {
  shift
  printf 'Underlying command:\n  nix develop -c sbt '\''runMain learnai.Main train %s'\''\n\n' "$*"
  nix develop -c sbt "runMain learnai.Main train $*"
}

run_diagnostics() {
  explain \
    "MiniGPT correctness and local performance diagnostics" \
    "The model is not trained. Analytical gradients are compared with central differences; parameter payload is counted; repeated forward passes are timed." \
    "Gradient probes must pass. Inspect maximum error, median, p95, variation, checksum, JVM, OS, and CPU architecture." \
    "The local timing is not a portable benchmark and does not predict GPU or production throughput."
  run_main diagnostics
}

run_cache() {
  explain \
    "KV-cache decoding" \
    "Reference decoding recomputes the prefix while cached decoding retains attention keys/values and evaluates new tokens incrementally." \
    "Tokens/logits must remain equivalent. Compare token-work counts, cache bytes, rebuilds, and environment-labelled timings." \
    "This CPU microbenchmark does not reproduce a production serving engine or GPU kernel."
  run_main cache
}

run_quantization() {
  explain \
    "Symmetric int8 quantization" \
    "Rows of Double weights are scaled and rounded to signed 8-bit integers, reconstructed, and used in matrix-vector multiplication." \
    "Inspect maximum/mean reconstruction error, output error, and payload byte reduction." \
    "Weight reconstruction error alone does not establish downstream model quality or inference speed."
  run_main quantization
}

run_agent() {
  explain \
    "Deterministic agent evaluation" \
    "A scripted fake language model exercises direct answers, an allowed read-only lookup, and a denied write through the typed agent runtime." \
    "Every case should pass. Inspect requested versus physically attempted tools, approval errors, token counts, and terminal status." \
    "No remote LLM is called, so this tests runtime and policy correctness—not real-model tool-selection quality."
  run_main agent
}

run_planning() {
  explain \
    "Task-graph planning and recovery" \
    "A validated dependency graph schedules bounded worker-agent attempts, retries a failed task, and produces a resumable checkpoint." \
    "Inspect task order, attempts, dependency outputs, final statuses, usage, and checkpoint contents." \
    "The workers are deterministic fakes and checkpoint persistence is not a distributed workflow system."
  run_main planning
}

run_foundations() {
  explain \
    "Scala foundations" \
    "Small functions demonstrate immutable values, collections, pattern matching, Either-based errors, and the shared CLI entrypoint." \
    "Read each printed value and connect it to ScalaTour.scala before moving to mathematical code." \
    "This is a language orientation, not complete Scala or JVM training."
  run_main foundations
}

run_complexity() {
  explain \
    "Complexity and representation" \
    "Linear and binary search count comparisons; matrix traversals expose flat memory order; array growth counts copies; payload accounting counts bytes." \
    "Predict counts before reading them and distinguish deterministic work from noisy elapsed time." \
    "Operation counts do not model JIT, caches, GC, SIMD, or complete object overhead."
  run_main complexity
}

run_jvm() {
  explain \
    "JVM systems boundaries" \
    "The process reports heap capacity and processors, executes owned work with a deadline, and demonstrates explicit runtime outcomes." \
    "Distinguish maximum from allocated heap and verify the worker completes without leaking ownership." \
    "A thread timeout is not a process sandbox, and heap observations are not exact live-object measurements."
  run_main jvm
}

run_linear_algebra() {
  explain \
    "Deeper linear algebra" \
    "Pivoted elimination measures rank, power iteration estimates a dominant eigenpair, and a 2x2 reference exposes singular values and conditioning." \
    "Inspect the eigen residual and distinguish rank, singular strength, and sensitivity." \
    "The SVD path is intentionally 2x2 and is not a production numerical linear-algebra library."
  run_main linear-algebra
}

run_statistics() {
  explain \
    "Statistical inference and calibration" \
    "Sample estimates retain standard error and interval evidence; binary forecasts are grouped into reliability bins and summarized by weighted calibration error." \
    "Check sample count, interval width, every populated bin, and the aggregate ECE." \
    "A normal approximation and binned ECE do not establish representativeness, independence, or causal validity."
  run_main statistics
}

run_tensor_execution() {
  explain \
    "Tensor execution model" \
    "Explicit plans map broadcast coordinates, isolate batched matrix products, share backing storage through strided views, and account retained graph bytes." \
    "Inspect broadcast input offsets, transposed logical order, and activation bytes before release." \
    "The reference batch operation is forward-only and the immutable view/accounting model is not an optimized tensor runtime."
  run_main tensor-execution
}

run_precision() {
  explain \
    "Precision engineering" \
    "Values round through FP32, FP16, and BF16; reductions expose cancellation; dynamic loss scaling unscales finite gradients and skips overflowed updates." \
    "Compare local precision versus range, FP32 versus FP64 accumulation, and the explicit scaler state transition." \
    "Format simulation on Double tensors does not provide accelerator kernels, lower Tensor memory, or mixed-precision convergence evidence."
  run_main precision
}

run_xor() {
  explain \
    "Scalar autodiff and XOR MLP" \
    "A small multilayer perceptron uses the scalar reverse-mode graph to learn the nonlinear XOR truth table." \
    "Loss should fall and all four predictions should match their classes." \
    "Solving four points does not establish generalization or scalable tensor performance."
  run_main xor
}

run_bigram() {
  explain \
    "Bigram language model" \
    "A trainable token-to-next-token table learns a deterministic toy cycle and samples from its learned rows." \
    "Loss should fall and generated IDs should follow the cycle." \
    "A bigram model sees only the current token; it has no Transformer context or semantic understanding."
  run_main bigram
}

run_corpus_shards() {
  explain \
    "Corpus manifests and shards" \
    "UTF-8 text is split only at code-point boundaries, each shard and the whole corpus are hashed, and bounded reads return an exact resume cursor." \
    "Inspect provenance, contiguous byte ranges, SHA-256 verification, shard count, and a bounded first read." \
    "A local immutable file contract does not decide whether a source license permits training or provide distributed object-store transactions."
  run_main corpus-shards
}

run_tests() {
  explain \
    "Complete repository verification" \
    "sbt cleans and compiles production/test Scala, then runs every dependency-free suite." \
    "The final line must report zero failures. Earlier lines identify the exact suite and invariant." \
    "Passing tests establishes the covered contracts, not correctness for every possible input or production environment."
  printf 'Underlying command:\n  nix develop -c sbt check\n\n'
  nix develop -c sbt check
}

require_nix

case "${1:-help}" in
  help|-h|--help) usage ;;
  model) run_model ;;
  gpt-lineage) run_gpt_lineage ;;
  training) run_training ;;
  train) run_training_workflow "$@" ;;
  diagnostics) run_diagnostics ;;
  cache) run_cache ;;
  quantization) run_quantization ;;
  agent) run_agent ;;
  planning) run_planning ;;
  foundations) run_foundations ;;
  complexity) run_complexity ;;
  jvm) run_jvm ;;
  linear-algebra) run_linear_algebra ;;
  statistics) run_statistics ;;
  tensor-execution) run_tensor_execution ;;
  precision) run_precision ;;
  xor) run_xor ;;
  bigram) run_bigram ;;
  corpus-shards) run_corpus_shards ;;
  test) run_tests ;;
  tour)
    run_model
    run_training
    run_diagnostics
    run_agent
    ;;
  *)
    printf 'Unknown command: %s\n\n' "$1" >&2
    usage >&2
    exit 2
    ;;
esac
